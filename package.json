    "i18next": "^26.0.8",
    "jsbarcode": "^3.12.3",
    "papaparse": "^5.5.3",
    "puppeteer": "^24.42.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.2"
