# Copy this file to .env and fill in real values.
# Never commit .env to git — it is in .gitignore.

# Tells the app it is running in development mode (set automatically by npm run dev).
NODE_ENV=development

# App display name shown in title bars.
VITE_APP_NAME=Label Studio KH

# Secret used by the license key generator/validator (Phase 4 only).
# Leave blank during Phases 1–3. Will be generated and added when license system is built.
LICENSE_SECRET=
