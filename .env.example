# Copy this file to .env and fill in real values.
# Never commit .env to git — it is in .gitignore.

# Tells the app it is running in development mode (set automatically by npm run dev).
NODE_ENV=development

# App display name shown in title bars.
VITE_APP_NAME=Label Studio KH

# GitHub Personal Access Token for `npm run release` — uploads the built
# DMGs / EXEs to the GitHub Releases page via the API (much faster and more
# reliable than dragging files in the web UI).
#
# To generate:
#   1. Visit https://github.com/settings/tokens?type=beta  (or "Tokens classic")
#   2. New token → name it "label-studio-kh release"
#   3. Expiration: 90 days (or no expiration if you don't want to deal with it)
#   4. Scopes: check `repo` (the top one — full control over the repo)
#   5. Generate → copy the `ghp_…` value (it's shown exactly once)
#   6. Paste below — no quotes needed
#
# Only used at release time, on YOUR machine. Never bundled into the app or
# read by end users. If you ever suspect it leaked, revoke and regenerate at
# the same URL.
GH_TOKEN=
